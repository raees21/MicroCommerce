{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },
  "Jwt": {
    "Issuer": "microcommerce.identity",
    "Audience": "microcommerce.clients",
    "SigningKey": "super-secret-dev-key-change-me-please",
    "ExpirationMinutes": 120
  },
  "Storage": {
    "MongoConnectionString": "mongodb://localhost:27017",
    "MongoDatabaseName": "microcommerce",
    "RedisConnectionString": "localhost:6379"
  }
}
