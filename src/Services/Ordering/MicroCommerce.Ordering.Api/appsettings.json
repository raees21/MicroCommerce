{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1AndHttp2"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http2"
      }
    }
  },
  "Jwt": {
    "Issuer": "microcommerce.identity",
    "Audience": "microcommerce.clients",
    "SigningKey": "super-secret-dev-key-change-me-please",
    "ExpirationMinutes": 120
  },
  "Storage": {
    "PostgresConnectionString": "Host=localhost;Port=5432;Database=orderingdb;Username=postgres;Password=postgres",
    "MongoConnectionString": "mongodb://localhost:27017",
    "MongoDatabaseName": "microcommerce"
  },
  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "ClientId": "ordering-api",
    "ConsumerGroup": "ordering-api-group"
  },
  "ServiceEndpoints": {
    "ProductsGrpcUrl": "http://localhost:6003"
  }
}
