{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },
  "Jwt": {
    "Issuer": "microcommerce.identity",
    "Audience": "microcommerce.clients",
    "SigningKey": "super-secret-dev-key-change-me-please",
    "ExpirationMinutes": 120
  },
  "Storage": {
    "PostgresConnectionString": "Host=localhost;Port=5432;Database=paymentsdb;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "ClientId": "payments-api",
    "ConsumerGroup": "payments-api-group"
  }
}
